{
  "name": "election-backend",
  "version": "1.0.0",
  "description": "Election platform backend — Node.js + TypeScript + Express + MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node --project tsconfig.scripts.json scripts/seed.ts",
    "create-indexes": "ts-node --project tsconfig.scripts.json scripts/createIndexes.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1009.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "resend": "^3.2.0",
    "streamifier": "^0.1.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/streamifier": "^0.1.2",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
